# =====================================
# CONFIGURACIÓN DE ENTORNO - EJEMPLO
# =====================================
# Copia este archivo a .env.local para desarrollo
# o configura las variables en tu plataforma de despliegue

# Puerto del servidor
PORT=3000

# Entorno de la aplicación
NODE_ENV=development

# =====================================
# CONFIGURACIÓN DE CORS
# =====================================
# URLs permitidas para CORS (separadas por coma)
# Para desarrollo: http://localhost:5173,http://localhost:3000
# Para producción: https://tu-dominio.com,https://www.tu-dominio.com

CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# CORS origins for staging environment (comma-separated, required when NODE_ENV=staging)
CORS_ORIGINS_STAGING=https://tribehub-frontend.netlify.app

# =====================================
# CONFIGURACIÓN DE SUPABASE
# =====================================
# Reemplaza con tus credenciales reales de Supabase

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-supabase-service-role-key

# =====================================
# CONFIGURACIÓN DE JWT
# =====================================

JWT_SECRET=tu-jwt-secret-super-seguro-aqui
JWT_EXPIRES_IN=7d

# =====================================
# BASE DE DATOS
# =====================================

DATABASE_URL=postgresql://usuario:password@localhost:5432/nombre_db

# =====================================
# OTROS SERVICIOS
# =====================================

# Redis (si usas caché)
REDIS_URL=redis://localhost:6379

# Puerto del frontend para desarrollo
FRONTEND_URL=http://localhost:5173