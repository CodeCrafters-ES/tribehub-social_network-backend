  "scripts": {
    "preinstall": "node -e \"const a=process.env.npm_config_user_agent;if(a&&!a.startsWith('pnpm')){console.error('\\nUse pnpm to install dependencies: https://pnpm.io\\n');process.exit(1)}\"",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:ci": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:cov": "vitest run --config vitest.unit.config.ts --coverage",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
